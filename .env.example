# API Configuration
# Copy this file to .env and fill in your actual API credentials

# IMPORTANT: The app now automatically detects the platform and uses the correct URL:
# - Android Emulator: http://10.0.2.2:3000/api (10.0.2.2 maps to host machine's localhost)
# - iOS Simulator: http://localhost:3000/api (localhost works fine on iOS)
# - Physical Device: Use your computer's local IP address (e.g., http://192.168.1.100:3000/api)

# API Base URL - Your backend API endpoint
# For Android Emulator: API_BASE_URL=http://10.0.2.2:3000/api
# For iOS Simulator: API_BASE_URL=http://localhost:3000/api
# For Physical Device: API_BASE_URL=http://YOUR_COMPUTER_IP:3000/api
# For production: API_BASE_URL=https://your-domain.com/api
API_BASE_URL=http://10.0.2.2:3000/api

# Note: In Flutter, environment variables are set at build time.
# To override the auto-detected URL, rebuild with:
# flutter run --dart-define=API_BASE_URL=http://your-api-url.com/api

# Common Issues:
# 1. "Failed to fetch API" - Make sure backend server is running on port 3000
# 2. Android Emulator can't connect - Use 10.0.2.2 instead of localhost
# 3. Physical device can't connect - Use your computer's IP address, ensure both on same network
# 4. iOS Simulator issues - Check that backend allows connections from localhost
