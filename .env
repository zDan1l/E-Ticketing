# API Configuration for Physical Device/Chrome
# Untuk menjalankan di device fisik atau Chrome di device lain

# PENTING: Ganti IP_ADDRESS di bawah ini dengan IP address komputermu
# Cara mencari IP:
# - Windows: ipconfig (lihat IPv4 Address)
# - Mac/Linux: ifconfig | grep inet atau ip addr show

# Untuk Physical Device (Android/iOS) atau Chrome di device lain:
API_BASE_URL=http://192.168.1.100:3000/api

# Jangan lupa:
# 1. Pastikan device dan komputer berada di jaringan WiFi yang sama
# 2. Pastikan backend server running di komputermu pada port 3000
# 3. Jika menggunakan firewall, pastikan port 3000 diizinkan
